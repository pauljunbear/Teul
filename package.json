{
  "name": "teul",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "npm": "10.x"
  },
  "description": "Teul helps designers explore historical color, build tested color systems, and apply documented layout grids in Figma.",
  "main": "dist/code.js",
  "scripts": {
    "audit": "npm audit --audit-level=moderate",
    "build": "webpack --mode=production",
    "assert:artifacts": "node scripts/assert-build-artifacts.js",
    "check:ui-bundle": "node scripts/check-ui-bundle.js",
    "report:dead-code": "node scripts/report-dead-exports.js",
    "report:bundle": "node scripts/report-bundle-composition.js",
    "dev": "webpack --mode=development --watch",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:production-ui": "node scripts/smoke-production-ui.js",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:wada": "node scripts/verify-wada-upstream.mjs",
    "werner:sample": "node scripts/werner-sampling/sample.mjs",
    "prepare": "husky"
  },
  "author": "Paul Jun",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "lucide-react": "^1.24.0",
    "preact": "^10.29.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@figma/plugin-typings": "^1.82.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "html-webpack-plugin": "^5.5.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "ts-loader": "^9.5.1",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^7.0.2",
    "vitest": "^4.0.16",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
